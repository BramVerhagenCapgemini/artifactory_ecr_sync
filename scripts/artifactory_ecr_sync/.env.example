# Artifactory Configuration
ARTIFACTORY_URL=https://your-company.jfrog.io/artifactory
ARTIFACTORY_USER=your-username
ARTIFACTORY_TOKEN=your-api-token
ARTIFACTORY_REPO=docker-repo-name

# ECR Configuration  
ECR_REGION=us-east-1
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# Optional Filters (comma-separated)
IMAGE_FILTERS=app,service
TAG_FILTERS=latest,v1.0